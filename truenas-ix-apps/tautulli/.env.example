# Tautulli stack environment variables
# Copy this file to tautulli/.env and fill in all values.

# User and group IDs — should match the owner of the config directory
PUID=1000
PGID=1000

# Timezone
TZ=America/Your_Timezone

# Host path for Tautulli configuration and database
TAUTULLI_CONFIG_PATH=/path/to/config/tautulli

# Hostname exposed via traefik-private
TAUTULLI_HOST=tautulli.yourdomain.com
