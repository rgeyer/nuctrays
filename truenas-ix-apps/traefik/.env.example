# Traefik stack environment variables
# Copy this file to /mnt/.ix-apps/app_configs/traefik/.env and fill in all values.

# ---------------------------------------------------------------------------
# IP addresses — interface bindings for each Traefik instance
# ---------------------------------------------------------------------------

# Local LAN interface (eno1 existing alias)
TRAEFIK_PRIVATE_IP=192.168.x.x

# Internet-facing interface (eno1 new alias — must be assigned before deploying)
TRAEFIK_PUBLIC_IP=192.168.x.x

# AREDN mesh interface (eno2)
TRAEFIK_AREDN_IP=10.x.x.x

# ---------------------------------------------------------------------------
# ACME / Let's Encrypt (Route53 DNS challenge)
# ---------------------------------------------------------------------------

ACME_EMAIL=you@example.com

# AWS credentials for Route53 DNS challenge
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# ACME certificate storage paths (on the TrueNAS host)
# These files must exist before starting Traefik (touch the file and chmod 600)
#   touch /mnt/.ix-apps/app_configs/traefik/acme-private.json && chmod 600 /mnt/.ix-apps/app_configs/traefik/acme-private.json
#   touch /mnt/.ix-apps/app_configs/traefik/acme-public.json  && chmod 600 /mnt/.ix-apps/app_configs/traefik/acme-public.json
# ---------------------------------------------------------------------------

ACME_PRIVATE_PATH=/mnt/.ix-apps/app_configs/traefik/acme-private.json
ACME_PUBLIC_PATH=/mnt/.ix-apps/app_configs/traefik/acme-public.json
