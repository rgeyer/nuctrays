# Blackpearl stack environment variables
# Copy this file to /mnt/.ix-apps/app_configs/blackpearl/.env and fill in all values.

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------

TZ=America/Your_Timezone

# ---------------------------------------------------------------------------
# Config volume host paths
# These directories must exist on the TrueNAS host before starting the stack.
# Create them with:
#   mkdir -p /path/to/config/{radarr,sonarr,lidarr,readarr,nzbget,overseerr}
# ---------------------------------------------------------------------------

RADARR_CONFIG_PATH=/path/to/config/radarr
SONARR_CONFIG_PATH=/path/to/config/sonarr
LIDARR_CONFIG_PATH=/path/to/config/lidarr
READARR_CONFIG_PATH=/path/to/config/readarr
NZBGET_CONFIG_PATH=/path/to/config/nzbget
OVERSEERR_CONFIG_PATH=/path/to/config/overseerr

# ---------------------------------------------------------------------------
# NFS media share
# ---------------------------------------------------------------------------

MEDIA_NFS_SERVER=192.168.x.x
MEDIA_NFS_PATH=/path/to/media

# ---------------------------------------------------------------------------
# Traefik hostnames (exposed via traefik-private)
# ---------------------------------------------------------------------------

RADARR_HOST=radarr.yourdomain.com
SONARR_HOST=sonarr.yourdomain.com
LIDARR_HOST=lidarr.yourdomain.com
READARR_HOST=readarr.yourdomain.com
NZBGET_HOST=nzbget.yourdomain.com
OVERSEERR_HOST=overseerr.yourdomain.com
