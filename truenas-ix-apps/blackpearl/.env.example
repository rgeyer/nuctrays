# Blackpearl stack environment variables
# Copy this file to /mnt/.ix-apps/app_configs/blackpearl/.env and fill in all values.

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------

TZ=America/Your_Timezone

# ---------------------------------------------------------------------------
# VPN credentials (NordVPN service credentials — NOT your account login)
# Find these at: https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/
# ---------------------------------------------------------------------------

VPN_USER=your_nordvpn_service_username
VPN_PASSWORD=your_nordvpn_service_password

# Country (or comma-separated list) to connect to, e.g. "United States", "Netherlands"
VPN_SERVER_COUNTRIES=United States

# DNS server used inside the VPN tunnel.
# NordVPN's resolver (103.86.96.100) is reachable through the tunnel but
# applies a blocklist that may refuse some Usenet or P2P hostnames.
# Use 1.1.1.1 (Cloudflare) or 8.8.8.8 (Google) for neutral resolution —
# queries still travel through the tunnel so your ISP cannot see them.
VPN_DNS=1.1.1.1

# ---------------------------------------------------------------------------
# Config volume host paths
# These directories must exist on the TrueNAS host before starting the stack.
# Create them with:
#   mkdir -p /path/to/config/{radarr,sonarr,lidarr,readarr,nzbget,overseerr}
# ---------------------------------------------------------------------------

RADARR_CONFIG_PATH=/path/to/config/radarr
SONARR_CONFIG_PATH=/path/to/config/sonarr
# LIDARR_CONFIG_PATH=/path/to/config/lidarr  # uncomment when lidarr is re-enabled
READARR_CONFIG_PATH=/path/to/config/readarr
NZBGET_CONFIG_PATH=/path/to/config/nzbget
OVERSEERR_CONFIG_PATH=/path/to/config/overseerr

# ---------------------------------------------------------------------------
# Media volume host path
# This directory must exist on the TrueNAS host before starting the stack.
# ---------------------------------------------------------------------------

MEDIA_PATH=/path/to/media

# ---------------------------------------------------------------------------
# Traefik hostnames (exposed via traefik-private)
# ---------------------------------------------------------------------------

RADARR_HOST=radarr.yourdomain.com
SONARR_HOST=sonarr.yourdomain.com
LIDARR_HOST=lidarr.yourdomain.com
READARR_HOST=readarr.yourdomain.com
NZBGET_HOST=nzbget.yourdomain.com
OVERSEERR_HOST=overseerr.yourdomain.com
