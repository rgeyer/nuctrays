# openhamclock stack environment variables
# Copy this file to openhamclock/.env and fill in all values.

# Timezone
TZ=America/Your_Timezone

# Hostname of the private registry where the openhamclock image is hosted
# (used to pull the image)
REGISTRY_HOST=registry.yourdomain.com

# Host IP to bind the UDP port (typically your primary LAN IP)
HOST_IP=192.168.x.x

# Hostname for the private and public Traefik instances (same hostname for both)
OPENHAMCLOCK_HOST=openhamclock.yourdomain.com

# Hostname for the AREDN mesh Traefik instance
OPENHAMCLOCK_AREDN_HOST=yourhost.local.mesh
