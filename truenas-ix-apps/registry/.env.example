# Registry stack environment variables
# Copy this file to registry/.env and fill in all values.

# Hostname for the registry — must match a DNS record pointing at TRAEFIK_PRIVATE_IP
REGISTRY_HOST=registry.yourdomain.com

# Host path for persistent registry storage
# Create this directory before deploying:
#   mkdir -p /path/to/registry/data
REGISTRY_DATA_PATH=/path/to/registry/data
