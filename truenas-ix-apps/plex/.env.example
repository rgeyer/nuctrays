# Plex stack environment variables
# Copy this file to plex/.env and fill in all values.

# User and group IDs to run Plex as.
# Set to 0 (root) so Plex can read media files owned by any user.
# The media volume is mounted read-only (:ro) to prevent Plex from
# modifying or deleting files despite running as root.
PUID=0
PGID=0

# Timezone
TZ=America/Your_Timezone

# Host IP advertised to Plex's relay and used for direct connection URLs.
# This should be the primary LAN IP of the TrueNAS host.
# Note: with network_mode: host, Plex binds to all host interfaces automatically —
# HOST_IP only controls what is advertised to Plex cloud/clients.
HOST_IP=192.168.x.x

# Plex claim token — obtain a fresh one at https://plex.tv/claim (valid for 4 minutes)
# Only needed on first run to link the server to your Plex account.
# After the server is claimed, this value is ignored and can be left as-is or cleared.
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Volume paths — these live outside /mnt/.ix-apps for historical reasons and
# must exist on the host before deploying. No placeholder app is needed for
# these directories since they are managed externally.
# ---------------------------------------------------------------------------

# Host path for Plex configuration and metadata
PLEX_CONFIG_PATH=/path/to/plex/config

# Host path for media library (read-only access is sufficient if you prefer)
MEDIA_PATH=/path/to/media
